{
  "chat": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "fallback": [
      {
        "provider": "openrouter",
        "model": "deepseek/deepseek-chat-v3-0324"
      }
    ]
  },
  "content": {
    "provider": "anthropic",
    "model": "claude-sonnet-4-6",
    "fallback": [
      {
        "provider": "openrouter",
        "model": "deepseek/deepseek-chat-v3-0324"
      }
    ]
  },
  "world": {
    "provider": "dashscope",
    "model": "qwen-flash"
  },
  "plan": {
    "provider": "dashscope",
    "model": "qwen-flash"
  },
  "image": {
    "provider": "dashscope",
    "model": "wan2.2-t2i-flash",
    "fallback": [
      { "provider": "gemini", "model": "gemini-3-pro-image" },
      { "provider": "openrouter", "model": "google/gemini-3-pro-image-preview" }
    ]
  },
  "video": {
    "provider": "dashscope",
    "model": "wan2.2-i2v-flash",
    "fallback": [{ "provider": "kling", "model": "kling-v2-6" }]
  },
  "music":   { "provider": "dashscope", "model": "fun-music-v1",
               "fallback": [{ "provider": "suno", "model": "V5" }] },
  "tts": {
    "provider": "dashscope",
    "model": "qwen-tts"
  },
  "asr": {
    "provider": "dashscope",
    "model": "qwen3-asr-flash"
  },
  "providers": {}
}
